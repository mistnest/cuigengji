{
    "name": "cuigengji",
    "version": "1.0.0",
    "description": "催更姬 - AI 小说创作助手",
    "type": "module",
    "main": "electron/index.js",
    "author": "mistnest",
    "license": "SEE LICENSE IN LICENSE",
    "homepage": "https://github.com/mistnest/cuigengji",
    "repository": {
        "type": "git",
        "url": "https://github.com/mistnest/cuigengji.git"
    },
    "scripts": {
        "start": "node src/server.js",
        "start:electron": "node scripts/start-electron.js",
        "dev": "node --watch src/server.js",
        "build": "electron-builder",
        "build:win": "node scripts/build-win.js",
        "package:win": "node scripts/package-win.js",
        "package:win:test": "node scripts/package-win.js --with-tests",
        "lint": "eslint src/**/*.js public/**/*.js",
        "test": "npx playwright test",
        "test:smoke": "npx playwright test --grep @smoke",
        "test:api": "npx playwright test tests/api/",
        "test:e2e": "npx playwright test tests/e2e/",
        "test:electron": "node scripts/test-electron.js",
        "test:regression": "npx playwright test --grep @regression",
        "test:ui": "npx playwright test --ui",
        "test:report": "npx playwright show-report test-results/html",
        "test:install": "npx playwright install chromium",
        "fingerprint": "node scripts/create-fingerprint-manifest.js"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "body-parser": "^1.20.2",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "crc": "^4.3.2",
        "express": "^4.21.0",
        "ftfy": "^1.0.1",
        "handlebars": "^4.7.9",
        "iconv-lite": "^0.4.24",
        "jschardet": "^3.1.4",
        "lodash": "^4.18.1",
        "mammoth": "^1.12.0",
        "multer": "^2.1.1",
        "node-fetch": "^3.3.2",
        "open": "^10.2.0",
        "png-chunk-text": "^1.0.0",
        "png-chunks-extract": "^1.0.0",
        "sanitize-filename": "^1.6.3",
        "tiktoken": "^1.0.22",
        "uuid": "^11.0.0",
        "write-file-atomic": "^5.0.1",
        "yaml": "^2.8.3",
        "yargs": "^17.7.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "electron": "^33.4.11",
        "electron-builder": "^25.0.0",
        "eslint": "^8.57.1"
    },
    "engines": {
        "node": ">= 20"
    },
    "build": {
        "appId": "com.mistnest.cuigengji",
        "productName": "催更姬",
        "extraMetadata": {
            "cuigengjiSignature": "cgj-mistnest-2026-community-source",
            "cuigengjiSchemaOwner": "mistnest-cuigengji",
            "repository": "https://github.com/mistnest/cuigengji"
        },
        "directories": {
            "output": "dist"
        },
        "asar": false,
        "files": [
            "src/**/*",
            "public/**/*",
            "electron/**/*",
            "shared/**/*",
            "package.json"
        ],
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "public/avatar.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "shortcutName": "催更姬",
            "artifactName": "${productName}-${version}-setup-${arch}.${ext}"
        },
        "portable": {
            "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
        },
        "mac": {
            "target": [
                "dmg"
            ],
            "category": "public.app-category.productivity"
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "category": "Office"
        }
    }
}
