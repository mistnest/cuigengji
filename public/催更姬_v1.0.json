    },
    {
      "identifier": "cgj-import-plotHistory",
      "name": "前情导入",
      "role": "system",
      "content": "",
      "isSystemPrompt": true,
      "isMarker": true,
      "markerId": "cgj-import-plotHistory",
      "enabled": true,
      "disabled": false
    },
    {
      "identifier": "cgj-mode-standard",
      "name": "标准续写",
      "role": "user",
      "content": "标准续写模式喵，日常就用这个：\n- 从正文结尾自然接上，文风别变味\n- 该推的推该细的细，别偏科\n- 写 700字左右喵",
      "isSystemPrompt": false,
      "isMarker": false,
      "markerId": "",
      "enabled": true,
      "disabled": false
    },
    {
      "identifier": "cgj-mode-conservative",
      "name": "保守推进",
      "role": "user",
      "content": "保守模式喵，收着点写：\n- 就在当前场景里转，别换地方别加新人\n- 把眼前的细节写透，人物互动写细\n- 写 500 到 800 字就够了喵",
      "isSystemPrompt": false,
      "isMarker": false,
      "markerId": "",
      "enabled": false,
      "disabled": true
    },
    {
      "identifier": "cgj-mode-adventurous",
      "name": "大胆展开",
      "role": "user",
      "content": "大胆模式喵，放开写：\n- 该跳时间跳时间，该换场景换场景\n- 情节需要的话加新人、起冲突，都可以\n- 选一条大胆但有逻辑的方向往下推\n- 写 1000 到 2000 字喵",
      "isSystemPrompt": false,
      "isMarker": false,
      "markerId": "",
      "enabled": false,
      "disabled": true
    },
    {
      "identifier": "cgj-quality-checklist",
      "name": "自检清单",
      "role": "user",
      "content": "输出之前自己过一遍喵：\n1. 人称对不对——是不是第三人称？\n2. 禁词碰了没？\n3. 标签都关上了没？\n4. 逻辑顺不顺？\n5. 角色有没有 OOC？\n6. 结尾是具体动作还是在那内心独白？",
      "isSystemPrompt": false,
      "isMarker": false,
      "markerId": "",
      "enabled": true,
      "disabled": false
    },
    {
      "identifier": "cgj-quality-anti-repeat",
      "name": "反重复",
      "role": "user",
      "content": "别老重复一样的东西喵：\n- 前文用过的比喻别再来一遍\n- 句式别连着好几段都一样\n- 角色别老做同样的动作说同样的台词\n- 每次换个新角度写喵~",
      "isSystemPrompt": false,
      "isMarker": false,
      "markerId": "",
      "enabled": true,
      "disabled": false
    },
    {
      "identifier": "cgj-quality-ending",
      "name": "反烂尾",
      "role": "user",
      "content": "结尾别烂喵：\n- 用角色的一个具体动作收尾——他推门出去、她放下茶杯、雨停了\n- 别在那内心独白、别感慨风景、别升华人生\n- 也别总结，读者不傻喵",
      "isSystemPrompt": false,
      "isMarker": false,
      "markerId": "",
      "enabled": true,
      "disabled": false
    },
    {
      "identifier": "cgj-quality-no-lecture",
      "name": "反说教",
      "role": "user",
      "content": "别当人生导师喵：\n- 别评判角色做得对不对\n- 别借叙述者嘴巴输出价值观\n- 别把角色当喇叭喊你的道理\n- 故事的意义让读者自己咂摸喵",
      "isSystemPrompt": false,
      "isMarker": false,
      "markerId": "",
      "enabled": true,
      "disabled": false
    }
  ],
